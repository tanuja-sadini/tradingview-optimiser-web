---
import Base from '../layouts/Base.astro';
import DashboardPreview from '../components/DashboardPreview.astro';
import { getSession } from '../lib/session';

const { env } = Astro.locals.runtime;
const session = await getSession(Astro.request, env.SESSION_SECRET);
const user = session ? { email: session.email } : null;
---

<Base
  title="TradingView Optimizer — The parameter optimizer TradingView doesn't have"
  description="Automatically sweep every combination of your TradingView strategy parameters. Ranked results, heatmaps, one-click deploy. macOS, Windows, Linux."
>

<!-- ════════ HERO ════════ -->
<section id="hero">
  <div class="hero-inner">

    <div class="hero-badge" aria-label="Status: Now Available">
      <span class="hero-badge-dot" aria-hidden="true"></span>
      Now Available &nbsp;·&nbsp; macOS · Windows · Linux
    </div>

    <h1 class="hero-h1">
      The parameter optimizer<br /><em>TradingView doesn't have.</em>
    </h1>

    <p class="hero-sub">
      Define your parameter ranges. Hit Run. Come back to ranked results,
      heatmaps, and the best setup your strategy can produce — no manual
      clicking required.
    </p>

    <div class="hero-actions">
      <a href="/pricing" class="btn-primary">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 8h12M8 2l6 6-6 6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Get Started
      </a>
      <a href="#how-it-works" class="btn-ghost">See how it works</a>
    </div>

    <p class="hero-note">
      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      macOS · Windows · Linux &nbsp;·&nbsp; All data stored locally
    </p>

    <div class="hero-stats reveal">
      <div class="hero-stat">
        <div class="hero-stat-value mono" data-count-text="Unlimited">0</div>
        <div class="hero-stat-label">combinations per run</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-value mono">5</div>
        <div class="hero-stat-label">analytics views</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-value mono">0</div>
        <div class="hero-stat-label">cloud dependencies</div>
      </div>
    </div>

  </div>

  <div class="container">
    <DashboardPreview />
  </div>
</section>

<!-- ════════ THE PROBLEM ════════ -->
<section id="problem">
  <div class="container">
    <p class="section-label reveal">The Problem</p>
    <h2 class="section-title reveal">TradingView has no parameter sweep tool.</h2>
    <p class="section-sub reveal" style="margin-bottom:48px">
      Finding the best combination of strategy settings means manually changing inputs and re-running the backtest — one by one. Slow, error-prone, and incomplete by the time you're done.
    </p>

    <div class="problem-grid reveal">
      <div class="problem-card before">
        <div class="problem-card-label">
          <span class="label-dot" aria-hidden="true"></span>
          Without TradingView Optimizer
        </div>
        <div class="terminal" aria-label="Manual backtesting terminal example">
          <div><span class="t-prompt"># </span><span class="t-out">Open settings dialog...</span></div>
          <div><span class="t-prompt">&gt; </span><span class="t-cmd">Set TP = 10, run backtest</span><span class="t-out"> (18s)</span></div>
          <div><span class="t-prompt">&gt; </span><span class="t-cmd">Set TP = 15, run backtest</span><span class="t-out"> (18s)</span></div>
          <div><span class="t-prompt">&gt; </span><span class="t-cmd">Set TP = 20, run backtest</span><span class="t-out"> (18s)</span></div>
          <div><span class="t-dim">... 2 hours later ...</span></div>
          <div><span class="t-err">✗ 12 combinations checked</span></div>
          <div><span class="t-warn">⚠ Hundreds more remaining — forgot SL sweep</span></div>
          <div><span class="t-err">✗ Already forgot row 3 results</span></div>
        </div>
        <p class="problem-pain">Hours of clicking. Incomplete coverage. Results you can't trust.</p>
      </div>

      <div class="problem-card after">
        <div class="problem-card-label">
          <span class="label-dot" aria-hidden="true"></span>
          With TradingView Optimizer
        </div>
        <div class="terminal" aria-label="Automated sweep terminal example">
          <div><span class="t-ok">✓ </span><span class="t-out">Parameters extracted from chart</span></div>
          <div><span class="t-ok">✓ </span><span class="t-out">Sweep configured — all combinations queued</span></div>
          <div><span class="t-prompt">&gt; </span><span class="t-cmd">Run started — unattended overnight</span></div>
          <div>&nbsp;</div>
          <div><span class="t-out">████████████████████ </span><span class="t-ok">100%</span></div>
          <div><span class="t-ok">✓ </span><span class="t-out">All combinations complete · 4h 12m</span></div>
          <div>&nbsp;</div>
          <div><span class="t-ok">✓ </span><span class="t-out">Best: TP=25, SL=15, HTF=15m</span></div>
          <div><span class="t-ok">✓ </span><span class="t-out">Score 87.3 · PF 2.31 · DD −8.2%</span></div>
        </div>
        <p class="problem-pain" style="color:var(--green)">Full coverage. Ranked results. Ready to deploy.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════════ HOW IT WORKS ════════ -->
<section id="how-it-works">
  <div class="how-header container">
    <p class="section-label reveal">How It Works</p>
    <h2 class="section-title reveal">Six steps from strategy to best setup.</h2>
    <p class="section-sub reveal">The app controls TradingView in a real browser session — no unofficial API, no compromises.</p>
  </div>

  <div class="steps-grid container">
    {[
      { n: '01', title: 'Create a project',       desc: 'Name your project and paste your TradingView chart URL. A 4-step wizard walks you through project details, TradingView session setup, parameter extraction, and confirmation.' },
      { n: '02', title: 'Extract parameters',     desc: 'The app opens your chart and reads every strategy input directly from the settings dialog — labels, types, and default values. You don\'t type a single parameter name.' },
      { n: '03', title: 'Configure your sweep',   desc: 'For each input: sweep a numeric range (start / end / step), select multiple option values, or toggle booleans. The combination count updates in real time as you configure.' },
      { n: '04', title: 'Run unattended',          desc: 'Hit Run. The app changes parameters, waits for the backtest to recalculate, reads performance metrics, and moves to the next combination. Thousands of runs overnight.' },
      { n: '05', title: 'Analyse results',         desc: 'Switch to the Results tab. Ranked table, parameter impact charts, scatter plots, and heatmaps give you a complete picture of your strategy\'s behaviour across the full sweep.' },
      { n: '06', title: 'Deploy to chart',         desc: 'Found your winner? Click Deploy. The app applies those exact parameters back to your TradingView chart — create a new copy, or overwrite the existing layout directly.' },
    ].map((step, i) => (
      <div class="step-card reveal" style={`transition-delay:${i * 0.05 + 0.05}s`}>
        <div class="step-number">STEP {step.n}</div>
        <div class="step-title">{step.title}</div>
        <p class="step-desc">{step.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- ════════ FEATURES ════════ -->
<section id="features">
  <div class="features-header container">
    <p class="section-label reveal">Features</p>
    <h2 class="section-title reveal">Built for complete coverage.</h2>
    <p class="section-sub reveal">Works with any Pine Script strategy. Every parameter type. Every market.</p>
  </div>

  <div class="features-grid container">
    <div class="feature-card reveal" style="transition-delay:0.05s">
      <div class="feature-icon" aria-hidden="true">🎛️</div>
      <div class="feature-title">Automated Parameter Sweeps</div>
      <p class="feature-desc">Define numeric ranges, select multiple option values, or toggle booleans. The app generates the full cartesian product and runs every combination automatically.</p>
      <div class="feature-tags">
        <span class="feature-tag">numeric range</span>
        <span class="feature-tag">option sweep</span>
        <span class="feature-tag">boolean sweep</span>
        <span class="feature-tag">cartesian product</span>
      </div>
    </div>

    <div class="feature-card reveal" style="transition-delay:0.10s">
      <div class="feature-icon" aria-hidden="true">⚡</div>
      <div class="feature-title">One-Click Parameter Extraction</div>
      <p class="feature-desc">The app reads every strategy input directly from your TradingView chart — no manual entry. After extraction, every input is ready to configure immediately.</p>
      <div class="feature-tags">
        <span class="feature-tag">auto-detect</span>
        <span class="feature-tag">any Pine Script strategy</span>
        <span class="feature-tag">zero typing</span>
      </div>
    </div>

    <div class="feature-card reveal" style="transition-delay:0.15s">
      <div class="feature-icon" aria-hidden="true">🌐</div>
      <div class="feature-title">Instrument &amp; Timeframe Sweeping</div>
      <p class="feature-desc">Sweep across multiple instruments and timeframes in a single run. Compare ES 15s vs NQ 15s vs ES 30s without running separate jobs.</p>
      <div class="feature-tags">
        <span class="feature-tag">ES NQ MNQ MES</span>
        <span class="feature-tag">GC BTCUSDT XAUUSD</span>
        <span class="feature-tag">5s → 1M timeframes</span>
      </div>
    </div>

    <div class="feature-card reveal" style="transition-delay:0.20s">
      <div class="feature-icon" aria-hidden="true">↩️</div>
      <div class="feature-title">Resume &amp; Deploy</div>
      <p class="feature-desc">If a run is stopped or crashes, resume from exactly where it left off — completed combinations are skipped, failed ones retried. Found your winner? One-click deploy back to your chart.</p>
      <div class="feature-tags">
        <span class="feature-tag">resume from interrupt</span>
        <span class="feature-tag">one-click deploy</span>
        <span class="feature-tag">new copy or overwrite</span>
      </div>
    </div>
  </div>
</section>

<!-- ════════ ANALYTICS ════════ -->
<section id="analytics">
  <div class="analytics-header container">
    <p class="section-label reveal">Analytics Dashboard</p>
    <h2 class="section-title reveal">Five views. Every angle covered.</h2>
    <p class="section-sub reveal">Results ranked by a composite score: 40% Win Rate, 30% Profit Factor, 20% Max Drawdown, 10% Net Profit.</p>
  </div>

  <div class="analytics-grid container">

    <div class="analytics-card reveal" style="transition-delay:0.05s">
      <div class="analytics-card-title">Parameter Impact Charts</div>
      <div class="analytics-card-desc">Median performance by parameter value. See which setting moves the needle most.</div>
      <div class="impact-bars" aria-label="Parameter impact chart">
        {[
          { label: 'HTF = 15m', width: 82, val: '82.4' },
          { label: 'HTF = 5m',  width: 71, val: '71.1' },
          { label: 'HTF = 1h',  width: 58, val: '58.3' },
          { label: 'HTF = 30m', width: 49, val: '49.7' },
          { label: 'HTF = 3m',  width: 38, val: '38.2' },
        ].map((row, i) => (
          <div class="impact-row">
            <div class="impact-label">{row.label}</div>
            <div class="impact-bar-bg"><div class="impact-bar-fill" style={`width:${row.width}%;opacity:${1 - i * 0.15}`}></div></div>
            <div class="impact-val">{row.val}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="analytics-card reveal" style="transition-delay:0.10s">
      <div class="analytics-card-title">Heatmap</div>
      <div class="analytics-card-desc">Pick any two swept parameters for the axes. Color scale = composite score.</div>
      <div class="heatmap-grid" aria-label="Heatmap of TP Distance vs SL Distance">
        <div class="hm-axis"></div>
        {['10','15','20','25','30','35','40'].map(v => <div class="hm-axis">{v}</div>)}
        {[
          { axis: '10', cells: [0.15,0.28,0.45,0.55,0.35,0.30,0.18] },
          { axis: '15', cells: [0.22,0.40,0.50,0.80,0.60,0.45,0.25] },
          { axis: '20', cells: [0.18,0.32,0.52,0.45,0.38,0.38,0.20] },
          { axis: '25', cells: [0.12,0.22,0.35,0.30,0.28,0.22,0.14] },
        ].map(row => (
          <>
            <div class="hm-axis">{row.axis}</div>
            {row.cells.map(opacity => (
              <div class="hm-cell" style={`background:rgba(${opacity > 0.5 ? '35,165,90' : '88,101,242'},${opacity})`}></div>
            ))}
          </>
        ))}
      </div>
      <div class="heatmap-legend">
        <span>← TP Distance →</span>
        <span class="heatmap-scale-wrap">
          <span class="heatmap-scale"></span>score
        </span>
      </div>
    </div>

    <div class="analytics-card reveal" style="transition-delay:0.15s">
      <div class="analytics-card-title">Tradeoff Scatter Plot</div>
      <div class="analytics-card-desc">Net Profit vs Max Drawdown. Green = Pareto frontier.</div>
      <div class="scatter-area" role="img" aria-label="Scatter plot of Net Profit vs Max Drawdown">
        <div class="scatter-axis-x" aria-hidden="true"></div>
        <div class="scatter-axis-y" aria-hidden="true"></div>
        {[
          [45,70],[55,65],[38,58],[62,72],[70,60],[30,75],[50,80],[65,50],[42,45],[58,42],[75,68],[35,82],[80,55]
        ].map(([l,t]) => <div class="scatter-dot" style={`left:${l}%;top:${t}%`}></div>)}
        {[
          [85,38],[78,32],[88,48],[72,28]
        ].map(([l,t]) => <div class="scatter-dot pareto" style={`left:${l}%;top:${t}%`}></div>)}
      </div>
      <div class="scatter-labels">
        <span>← Lower Drawdown</span>
        <span>Higher Net P&amp;L →</span>
      </div>
    </div>

    <div class="analytics-card reveal" style="transition-delay:0.20s">
      <div class="analytics-card-title">Run Comparison</div>
      <div class="analytics-card-desc">Load any two runs side by side and compare top results.</div>
      <div class="compare-legend">
        <span class="compare-legend-item"><span class="compare-swatch a"></span>Sweep A</span>
        <span class="compare-legend-item"><span class="compare-swatch b"></span>Sweep B</span>
      </div>
      <div class="compare-bars" aria-label="Run comparison">
        {[
          { label: 'Win Rate',      a: 64, b: 72, aVal: '64.2%',  bVal: '71.8%'  },
          { label: 'Profit Factor', a: 77, b: 65, aVal: '2.31',   bVal: '1.94'   },
          { label: 'Max Drawdown',  a: 27, b: 38, aVal: '8.2%',   bVal: '11.4%'  },
          { label: 'Net Profit',    a: 80, b: 63, aVal: '$12,450', bVal: '$9,820' },
        ].map(row => (
          <div class="compare-row">
            <div class="compare-label"><span>{row.label}</span><span>{row.aVal} vs {row.bVal}</span></div>
            <div class="compare-track">
              <div class="compare-bar a" style={`width:${row.a}%`}></div>
              <div class="compare-bar b" style={`width:${row.b}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- ════════ PRICING CTA ════════ -->
<section id="cta">
  <div class="container">
    <div class="cta-card reveal">
      <h2 class="cta-card-title">Ready to stop clicking?</h2>
      <p class="cta-card-sub">$19.99/month or $199.99/year. Full access. Cancel anytime.</p>
      <div class="cta-actions">
        <a href="/pricing" class="btn-primary cta-btn">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 8h12M8 2l6 6-6 6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          View Pricing
        </a>
        {!user && <a href="/auth/login" class="btn-ghost cta-btn">Sign In</a>}
      </div>
      <p class="cta-note">macOS · Windows · Linux &nbsp;·&nbsp; All data stored locally</p>
    </div>
  </div>
</section>

</Base>

<style>
/* ── Hero ── */
#hero {
  padding: 96px 24px 0;
  text-align: center;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

#hero::before {
  content: '';
  position: absolute;
  top: -100px; left: 50%;
  transform: translateX(-50%);
  width: 900px; height: 600px;
  background: radial-gradient(ellipse at center, rgba(88,101,242,0.18) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 760px;
  margin: 0 auto;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 4px 14px 4px 10px;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  margin-bottom: 28px;
}

.hero-badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2.5s ease-in-out infinite;
  flex-shrink: 0;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(35,165,90,0.4); }
  50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(35,165,90,0); }
}

.hero-h1 {
  font-size: clamp(34px, 5.5vw, 58px);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: 20px;
}

.hero-h1 em { font-style: normal; color: var(--accent); }

.hero-sub {
  font-size: clamp(15px, 2vw, 17px);
  color: var(--text-muted);
  max-width: 520px;
  margin: 0 auto 36px;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.hero-note {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.hero-stats {
  display: flex;
  justify-content: center;
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  max-width: 560px;
  margin: 0 auto 64px;
}

.hero-stat {
  flex: 1;
  padding: 18px 24px;
  text-align: center;
  position: relative;
}

.hero-stat + .hero-stat::before {
  content: '';
  position: absolute;
  left: 0; top: 20%; height: 60%; width: 1px;
  background: var(--border);
}

.hero-stat-value { font-size: 22px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.02em; }
.hero-stat-label { font-size: 11px; color: var(--text-muted); margin-top: 3px; }

/* ── Problem ── */
#problem { padding: 120px 24px; position: relative; z-index: 1; }

.problem-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.problem-card { padding: 40px; border-radius: var(--radius-md); border: 1px solid var(--border); }
.problem-card.before { background: var(--bg-panels); }
.problem-card.after  { background: var(--bg-cards); }

.problem-card-label {
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  margin-bottom: 20px;
  display: flex; align-items: center; gap: 7px;
}
.problem-card.before .problem-card-label { color: var(--red); }
.problem-card.after  .problem-card-label { color: var(--green); }

.label-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.problem-card.before .label-dot { background: var(--red); }
.problem-card.after  .label-dot { background: var(--green); }

.terminal {
  background: var(--bg-darkest);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 16px 18px;
  font-family: 'Noto Sans Mono', monospace;
  font-size: 12px;
  line-height: 1.8;
}

.t-prompt { color: var(--text-muted); }
.t-cmd    { color: var(--text-primary); }
.t-out    { color: var(--text-muted); }
.t-ok     { color: var(--green); }
.t-err    { color: var(--red); }
.t-warn   { color: var(--yellow); }
.t-dim    { color: rgba(255,255,255,0.25); }

.problem-pain { margin-top: 20px; font-size: 13px; color: var(--text-muted); font-style: italic; }

@media (max-width: 720px) { .problem-grid { grid-template-columns: 1fr; } }

@media (max-width: 600px) {
  #hero { padding: 64px 16px 0; }

  .hero-badge { font-size: 11px; padding: 4px 10px 4px 8px; }

  .hero-stats { max-width: 100%; }
  .hero-stat { padding: 12px 16px; }
  .hero-stat-value { font-size: 18px; }

  #problem { padding: 72px 16px; }
  .problem-card { padding: 24px; }
  .terminal { font-size: 11px; padding: 12px 14px; overflow-x: auto; }

  #how-it-works { padding: 0 16px 72px; }
  .how-header { margin-bottom: 40px; }

  #features { padding: 0 16px 72px; }
  .features-header { margin-bottom: 40px; }
  .feature-card { padding: 24px; }

  #analytics { padding: 0 16px 72px; }
  .analytics-header { margin-bottom: 40px; }

  #cta { padding: 0 16px 72px; }
  .cta-card { padding: 40px 24px; }

  .impact-row { grid-template-columns: 64px 1fr 44px; }
}

/* ── How It Works ── */
#how-it-works { padding: 0 24px 120px; position: relative; z-index: 1; }
.how-header { margin-bottom: 64px; }

.steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.step-card {
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 28px 28px 32px;
}

.step-number { font-family: 'Noto Sans Mono', monospace; font-size: 11px; font-weight: 600; color: var(--accent); margin-bottom: 12px; letter-spacing: 0.05em; }
.step-title  { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
