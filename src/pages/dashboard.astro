---
import Base from '../layouts/Base.astro';
import { getValidSession, parseAccessToken } from '../lib/session';

const { env } = Astro.locals.runtime;
const oidc = { authorizeUrl: env.OIDC_AUTHORIZE_URL, tokenUrl: env.OIDC_TOKEN_URL, logoutUrl: env.OIDC_LOGOUT_URL };
const result = await getValidSession(Astro.request, env.SESSION_SECRET, env.ASGARDEO_CLIENT_ID, env.ASGARDEO_CLIENT_SECRET, oidc);

if (!result) {
  return Astro.redirect('/auth/login?next=/dashboard');
}

const { session, newCookie } = result;
if (newCookie) Astro.response.headers.append('Set-Cookie', newCookie);

const tokenClaims = parseAccessToken(session.access_token);
const email = (tokenClaims?.email as string) ?? session.email ?? '—';

// Fetch user profile from backend
let profile: {
  user_id: string;
  subscription: { plan_id: string; status: string; current_period_end: number | null } | null;
  usage: Record<string, { count: number }>;
} | null = null;
let profileError: string | null = null;

try {
  const res = await fetch('https://api.tradingviewoptimizer.com/v1/me', {
    headers: { Authorization: `Bearer ${session.access_token}` },
  });
  if (res.ok) {
    profile = await res.json();
  } else {
    const body = await res.text();
    profileError = `${res.status}: ${body}`;
    console.error('[dashboard] /v1/me failed:', profileError);
  }
} catch (e) {
  profileError = String(e);
  console.error('[dashboard] /v1/me fetch error:', e);
}

const sub      = profile?.subscription ?? null;
const usage    = profile?.usage ?? {};
const isActive = sub && ['active', 'trialing'].includes(sub.status);
const isPaidSub = isActive && sub?.plan_id !== 'free';

function formatDate(ts: number | null | undefined): string {
  if (!ts) return '—';
  return new Date(ts * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function planLabel(planId: string | undefined): string {
  if (planId === 'monthly') return 'Monthly';
  if (planId === 'annual')  return 'Annual';
  return 'Free';
}

const params = new URL(Astro.request.url).searchParams;
const checkoutActivating = params.get('checkout') === 'success';  // polling state
const checkoutActivated  = params.get('activated') === '1';       // confirmed active

---

<Base
  title="Dashboard — TradingView Strategy Optimizer"
  description="Your TVO account dashboard."
  subscription={isPaidSub ? sub : null}
>

<section id="dashboard">
  <div class="container">

    <div class="dash-header">
      <div>
        <h1 class="dash-title">Dashboard</h1>
        <p class="dash-email">{session.email ?? session.user_id}</p>
      </div>
    </div>

    {checkoutActivated && (
      <div class="alert alert-success" role="status">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13.5 4.5L6.5 11.5L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Subscription activated. Welcome aboard.
      </div>
    )}

    {checkoutActivating && (
      <div class="alert alert-activating" id="activatingBanner" role="status" aria-live="polite">
        <span class="activating-spinner" aria-hidden="true"></span>
        <span id="activatingMsg">Your subscription is activating&hellip;</span>
      </div>
    )}

    <div class="dash-grid">

      <!-- Subscription card -->
      <div class="dash-card">
        <div class="dash-card-label">Subscription</div>

        {isPaidSub ? (
          <div class="sub-details">
            <div class="sub-row">
              <span class="sub-key">Plan</span>
              <span class="sub-val">{planLabel(sub?.plan_id)}</span>
            </div>
            <div class="sub-row">
              <span class="sub-key">Status</span>
              <span class="status-badge status-active">
                <span class="status-dot"></span>
                {sub?.status === 'trialing' ? 'Trial' : 'Active'}
              </span>
            </div>
            <div class="sub-row">
              <span class="sub-key">Renews</span>
              <span class="sub-val">{formatDate(sub?.current_period_end)}</span>
            </div>
            <button class="btn-ghost sub-manage-btn" id="manageSubBtn">Manage subscription</button>
          </div>
        ) : (
          <div class="sub-empty">
            <p>You're on the free plan.</p>
            <a href="/pricing" class="btn-primary sub-upgrade-btn">View Plans</a>
          </div>
        )}
      </div>

      <!-- Account card -->
      <div class="dash-card">
        <div class="dash-card-label">Account</div>
        <div class="account-rows">
          <div class="account-row">
            <span class="account-key">Email</span>
            <span class="account-val">{email}</span>
          </div>
          <div class="account-row">
            <span class="account-key">User ID</span>
            <span class="account-val mono account-uid">{session.user_id}</span>
          </div>
          <div class="account-row">
            <span class="account-key">Download</span>
            <a href="/download" class="account-link">
              Get the app for macOS, Windows &amp; Linux →
            </a>
          </div>
        </div>
      </div>

      <!-- Usage card -->
      <div class="dash-card dash-card-full">
        <div class="dash-card-label">Usage — this month</div>
        {Object.keys(usage).length > 0 ? (
          <div class="usage-list">
            {Object.entries(usage).map(([metric, data]) => (
              <div class="usage-row">
                <span class="usage-metric">{metric}</span>
                <span class="usage-count mono">{data.count}</span>
              </div>
            ))}
          </div>
        ) : (
          <p class="dash-empty-text">No usage recorded yet.</p>
        )}
      </div>

    </div>
  </div>
</section>

<script>
  const banner = document.getElementById('activatingBanner');
  if (banner) {
    const msg        = document.getElementById('activatingMsg')!;
    const INTERVAL   = 2000;   // poll every 2s
    const TIMEOUT    = 15000;  // give up after 15s
    const started    = Date.now();

    async function poll() {
      try {
        const res  = await fetch('/api/me');
        if (res.status === 401) return;           // session gone — stop
        const data = await res.json();
        const sub  = data?.subscription;
        const active = sub && ['active', 'trialing'].includes(sub.status);

        if (active) {
          window.location.replace('/dashboard?activated=1');
          return;
        }
      } catch { /* network hiccup — keep trying */ }

      if (Date.now() - started >= TIMEOUT) {
        banner.classList.remove('alert-activating');
        banner.classList.add('alert-error');
        msg.innerHTML =
          'We couldn\'t confirm your subscription yet. If you were charged, please contact us at ' +
          '<a href="mailto:contact@tradingviewoptimizer.com">contact@tradingviewoptimizer.com</a>.';
        return;
      }

      setTimeout(poll, INTERVAL);
    }

    setTimeout(poll, INTERVAL);
  }

  // Manage subscription
  const manageBtn = document.getElementById('manageSubBtn') as HTMLButtonElement | null;
  if (manageBtn) {
    manageBtn.addEventListener('click', async () => {
      manageBtn.disabled = true;
      manageBtn.textContent = 'Loading…';
      try {
        const res = await fetch('/api/portal', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ return_url: window.location.href }),
        });
        if (!res.ok) throw new Error(await res.text());
        const { url } = await res.json();
        window.location.href = url;
      } catch {
        manageBtn.disabled = false;
        manageBtn.textContent = 'Manage subscription';
      }
    });
  }
</script>

</Base>

<style>
#dashboard {
  padding: 64px 24px 120px;
  position: relative;
  z-index: 1;
  min-height: calc(100vh - 60px);
}

.dash-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 32px;
  max-width: 900px;
}

.dash-title {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.dash-email {
  font-size: 13px;
  color: var(--text-muted);
}


.alert {
  max-width: 900px;
  padding: 14px 18px;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.alert-success {
  background: rgba(35,165,90,0.1);
  border: 1px solid rgba(35,165,90,0.25);
  color: var(--green);
}

.alert-activating {
  background: rgba(88,101,242,0.08);
  border: 1px solid rgba(88,101,242,0.2);
  color: var(--accent);
}

.alert-error {
  background: rgba(242,63,67,0.08);
  border: 1px solid rgba(242,63,67,0.2);
  color: var(--red);
}

.alert-error a {
  color: var(--red);
  text-decoration: underline;
}

.activating-spinner {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(88,101,242,0.3);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.dash-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  max-width: 900px;
}

.dash-card {
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 28px;
}

.dash-card-full {
  grid-column: 1 / -1;
}

.dash-card-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 20px;
}

/* Subscription */
.sub-details { display: flex; flex-direction: column; gap: 14px; }

.sub-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
}

.sub-key { color: var(--text-muted); }
.sub-val { color: var(--text-primary); font-weight: 500; }

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 500;
}

.status-active { color: var(--green); }

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  animation: pulse 2.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(35,165,90,0.4); }
  50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(35,165,90,0); }
}

.sub-empty {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.sub-empty p {
  font-size: 13px;
  color: var(--text-muted);
}

.sub-upgrade-btn { align-self: flex-start; }

.sub-manage-btn {
  align-self: flex-start;
  margin-top: 8px;
  font-size: 12px;
  padding: 6px 12px;
}

/* Usage */
.usage-list { display: flex; flex-direction: column; gap: 12px; }

.usage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
}

.usage-metric {
  color: var(--text-muted);
  text-transform: capitalize;
}

.usage-count {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.dash-empty-text {
  font-size: 13px;
  color: var(--text-muted);
}

/* Account */
.account-rows { display: flex; flex-direction: column; gap: 14px; }

.account-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  font-size: 13px;
}

.account-key { color: var(--text-muted); flex-shrink: 0; }

.account-val {
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-uid {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 400;
}

.account-link {
  color: var(--accent);
  text-decoration: none;
  font-weight: 500;
}

.account-link:hover { text-decoration: underline; }

@media (max-width: 640px) {
  .dash-grid { grid-template-columns: 1fr; }
  .dash-card-full { grid-column: 1; }
}
</style>
