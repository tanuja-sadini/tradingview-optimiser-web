---
import Base from '../layouts/Base.astro';
import { getValidSession } from '../lib/session';
import { interpretSubscription, planLabel, type Subscription } from '../lib/subscription';

const { env } = Astro.locals.runtime;
const oidc = { authorizeUrl: env.OIDC_AUTHORIZE_URL, tokenUrl: env.OIDC_TOKEN_URL, logoutUrl: env.OIDC_LOGOUT_URL };
const result = await getValidSession(Astro.request, env.SESSION_SECRET, env.ASGARDEO_CLIENT_ID, env.ASGARDEO_CLIENT_SECRET, oidc);
const session = result?.session ?? null;
if (result?.newCookie) Astro.response.headers.append('Set-Cookie', result.newCookie);

const isLoggedIn = !!session;

// Fetch subscription for logged-in users
let currentSub: Subscription | null = null;
if (session) {
  try {
    const res = await fetch('https://api.tradingviewoptimizer.com/v1/me', {
      headers: { Authorization: `Bearer ${session.access_token}` },
    });
    if (res.ok) {
      const profile = await res.json();
      currentSub = profile.subscription ?? null;
    }
  } catch {
    // non-fatal — pricing page still renders without subscription info
  }
}

const sub = interpretSubscription(currentSub);

const MONTHLY_PRICE  = 19.99;
const ANNUAL_PRICE   = 199.99;
const ANNUAL_MONTHLY = (ANNUAL_PRICE / 12).toFixed(2); // 16.67
const ANNUAL_SAVINGS = ((MONTHLY_PRICE * 12) - ANNUAL_PRICE).toFixed(0); // 40
---

<Base
  title="Pricing — TradingView Optimizer"
  description="Simple, transparent pricing. Monthly or annual. Full access on all plans. Cancel anytime."
  subscription={currentSub}
>

<section id="pricing-hero">
  <div class="container">
    <p class="section-label reveal">Pricing</p>
    <h1 class="pricing-title reveal">Simple, transparent pricing.</h1>
    <p class="pricing-sub reveal">Full access on every plan. No feature tiers, no usage limits, no surprises.</p>
  </div>
</section>

<section id="plans">
  <div class="container">

    {sub.state === 'paid-active' && (
      <div class="current-sub-banner reveal">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13.5 4.5L6.5 11.5L3 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        You're on the <strong>{planLabel(sub.plan_id)}</strong> plan.
        <a href="/dashboard">Manage subscription →</a>
      </div>
    )}

    {sub.state === 'trial-active' && (
      <div class="current-sub-banner trial-banner reveal">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 4.5v4l2.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Your free trial ends in <strong>{sub.daysRemaining} day{sub.daysRemaining === 1 ? '' : 's'}</strong>. Pick a plan to keep your access.
      </div>
    )}

    {sub.state === 'trial-expired' && (
      <div class="current-sub-banner expired-banner reveal">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Your free trial has ended. Subscribe below to restore access.
      </div>
    )}

    {sub.state === 'billing-issue' && (
      <div class="current-sub-banner expired-banner reveal">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 5v3.5M8 10.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Your subscription needs attention.
        <a href="/dashboard">Manage billing →</a>
      </div>
    )}

    <div class="plans-grid reveal">

      <!-- Monthly -->
      <div class="plan-card">
        <div class="plan-header">
          <div class="plan-name">Monthly</div>
          <div class="plan-price">
            <span class="price-amount">${MONTHLY_PRICE}</span>
            <span class="price-per">/ month</span>
          </div>
          <div class="plan-billing">Billed monthly. Cancel anytime.</div>
        </div>

        <ul class="plan-features">
          <li>Unlimited parameter sweep runs</li>
          <li>All 5 analytics views</li>
          <li>Instrument &amp; timeframe sweeping</li>
          <li>Named sweep configurations</li>
          <li>Resume interrupted runs</li>
          <li>One-click deploy to chart</li>
          <li>macOS, Windows &amp; Linux</li>
          <li>All data stored locally — zero cloud</li>
        </ul>

        {sub.state === 'paid-active' && sub.plan_id === 'monthly' ? (
          <span class="plan-current">Current plan</span>
        ) : sub.state === 'paid-active' ? (
          <a href="/dashboard" class="btn-ghost plan-cta plan-switch">Switch plan via dashboard →</a>
        ) : isLoggedIn ? (
          <button class="btn-ghost plan-cta" data-plan="monthly">Subscribe Monthly</button>
        ) : (
          <a href="/checkout/monthly" class="btn-ghost plan-cta">Get Started</a>
        )}
      </div>

      <!-- Annual (highlighted) -->
      <div class="plan-card plan-featured">
        <div class="plan-badge">Best Value — Save ${ANNUAL_SAVINGS}/year</div>
        <div class="plan-header">
          <div class="plan-name">Annual</div>
          <div class="plan-price">
            <span class="price-amount">${ANNUAL_MONTHLY}</span>
            <span class="price-per">/ month</span>
          </div>
          <div class="plan-billing">
            ${ANNUAL_PRICE} billed once per year.
            <span class="plan-saving">2 months free vs monthly.</span>
          </div>
        </div>

        <ul class="plan-features">
          <li>Everything in Monthly</li>
          <li>Priority support</li>
          <li>Early access to new features</li>
        </ul>

        {sub.state === 'paid-active' && sub.plan_id === 'annual' ? (
          <span class="plan-current">Current plan</span>
        ) : sub.state === 'paid-active' ? (
          <a href="/dashboard" class="btn-primary plan-cta plan-switch">Switch plan via dashboard →</a>
        ) : isLoggedIn ? (
          <button class="btn-primary plan-cta" data-plan="annual">Subscribe Annually</button>
        ) : (
          <a href="/checkout/annual" class="btn-primary plan-cta">Get Started</a>
        )}
      </div>

    </div>

    <div class="plans-footnote reveal">
      <span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Subscription activates immediately after payment.
      </span>
      <span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13.5 8A5.5 5.5 0 1 1 8 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M10.5 1.5l3 3-5.5 5.5L5 11l1-3.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        Cancel anytime from your dashboard.
      </span>
      <span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M5 4V3a3 3 0 0 1 6 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        All data stored locally — no cloud dependency.
      </span>
    </div>
  </div>
</section>

<section id="faq">
  <div class="container">
    <h2 class="faq-title reveal">Common questions</h2>
    <div class="faq-grid reveal">
      {[
        {
          q: 'What is included in the subscription?',
          a: 'Full access to all features: automated parameter sweeps, 5 analytics views (ranked table, impact charts, heatmap, scatter plots, run comparison), instrument & timeframe sweeping, resume from interruption, and one-click deploy back to TradingView.',
        },
        {
          q: 'Does the app work with any TradingView strategy?',
          a: 'Yes. Parameters are read directly from your TradingView strategy settings dialog — no manual configuration required. It works with any Pine Script strategy that uses numeric, select, or boolean inputs.',
        },
        {
          q: 'Is my data sent to the cloud?',
          a: 'No. All strategy parameters, backtest results, and sweep history are stored in a local SQLite database on your machine. Nothing is uploaded to any server.',
        },
        {
          q: 'What platforms are supported?',
          a: 'macOS, Windows, and Linux — all supported at launch.',
        },
        {
          q: 'Can I cancel my subscription?',
          a: 'Yes, at any time from your dashboard. You\'ll retain access until the end of the current billing period.',
        },
        {
          q: 'Do I need a specific TradingView plan?',
          a: 'No. The optimizer works with whatever TradingView plan you already have. It automates interactions with TradingView\'s Strategy Tester in a real browser session.',
        },
      ].map(item => (
        <details class="faq-item">
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

</Base>

<script>
  // Handle subscribe buttons (logged-in state)
  document.querySelectorAll<HTMLButtonElement>('button[data-plan]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const plan = btn.dataset.plan;
      btn.disabled = true;
      btn.textContent = 'Redirecting…';

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });

        if (res.status === 401) {
          window.location.href = `/auth/login?next=/pricing`;
          return;
        }

        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error(data.error ?? 'Unknown error');
        }
      } catch (e) {
        btn.disabled = false;
        btn.textContent = plan === 'annual' ? 'Subscribe Annually' : 'Subscribe Monthly';
        alert('Something went wrong. Please try again.');
      }
    });
  });
</script>

<style>
#pricing-hero {
  padding: 96px 24px 48px;
  text-align: center;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

#pricing-hero::before {
  content: '';
  position: absolute;
  top: -60px; left: 50%;
  transform: translateX(-50%);
  width: 700px; height: 400px;
  background: radial-gradient(ellipse at center, rgba(88,101,242,0.15) 0%, transparent 65%);
  pointer-events: none;
}

.pricing-title {
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: 16px;
}

.pricing-sub {
  font-size: 17px;
  color: var(--text-muted);
  max-width: 480px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ── Current subscription banner ── */
.current-sub-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(35,165,90,0.08);
  border: 1px solid rgba(35,165,90,0.2);
  border-radius: var(--radius-md);
  padding: 13px 18px;
  font-size: 13px;
  color: var(--green);
  max-width: 820px;
  margin: 0 auto 28px;
}

.current-sub-banner strong { color: var(--green); font-weight: 600; }
.current-sub-banner a { color: var(--green); text-decoration: underline; margin-left: auto; white-space: nowrap; }

.trial-banner {
  background: rgba(240,178,50,0.08);
  border-color: rgba(240,178,50,0.25);
  color: var(--yellow);
}
.trial-banner strong { color: var(--yellow); }
.trial-banner a      { color: var(--yellow); }

.expired-banner {
  background: rgba(242,63,67,0.08);
  border-color: rgba(242,63,67,0.25);
  color: var(--red);
}
.expired-banner strong { color: var(--red); }
.expired-banner a      { color: var(--red); }

/* ── Current plan CTA ── */
.plan-current {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 11px 22px;
  font-size: 13px;
  font-weight: 600;
  color: var(--green);
  border: 1px solid rgba(35,165,90,0.25);
  border-radius: var(--radius-sm);
  background: rgba(35,165,90,0.08);
}

.plan-current::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  flex-shrink: 0;
}

/* ── Plans ── */
#plans {
  padding: 48px 24px 80px;
  position: relative;
  z-index: 1;
}

.plans-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  max-width: 820px;
  margin: 0 auto 32px;
}

.plan-card {
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px;
  display: flex;
  flex-direction: column;
  position: relative;
}

.plan-card.plan-featured {
  background: var(--bg-cards);
  border-color: var(--accent);
  box-shadow: 0 0 0 1px rgba(88,101,242,0.2), 0 8px 32px rgba(88,101,242,0.08);
}

.plan-badge {
  position: absolute;
  top: -13px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--accent);
  color: #fff;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 14px;
  border-radius: 20px;
  white-space: nowrap;
  letter-spacing: 0.02em;
}

.plan-header { margin-bottom: 28px; }

.plan-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.plan-price {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 8px;
}

.price-amount {
  font-size: 42px;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  font-family: 'Noto Sans Mono', monospace;
}

.price-per {
  font-size: 15px;
  color: var(--text-muted);
}

.plan-billing {
  font-size: 12px;
  color: var(--text-muted);
  line-height: 1.5;
}

.plan-saving {
  color: var(--green);
  font-weight: 500;
}

.plan-features {
  list-style: none;
  margin-bottom: 32px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.plan-features li {
  font-size: 13px;
  color: var(--text-muted);
  padding-left: 20px;
  position: relative;
  line-height: 1.5;
}

.plan-features li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
  opacity: 0.7;
}

.plan-featured .plan-features li::before { opacity: 1; }

.plan-cta {
  width: 100%;
  justify-content: center;
  text-align: center;
}

.plan-switch {
  font-size: 12px;
  opacity: 0.7;
}

.plans-footnote {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 24px;
  max-width: 820px;
  margin: 0 auto;
  font-size: 12px;
  color: var(--text-muted);
}

.plans-footnote span {
  display: flex;
  align-items: center;
  gap: 6px;
}

/* ── FAQ ── */
#faq {
  padding: 0 24px 120px;
  position: relative;
  z-index: 1;
}

.faq-title {
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  margin-bottom: 32px;
  max-width: 820px;
  margin-left: auto;
  margin-right: auto;
}

.faq-grid {
  max-width: 820px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.faq-item {
  background: var(--bg-panels);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.faq-q {
  padding: 18px 20px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  cursor: pointer;
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  user-select: none;
}

.faq-q::-webkit-details-marker { display: none; }

.faq-q::after {
  content: '+';
  font-size: 18px;
  color: var(--text-muted);
  font-weight: 300;
  flex-shrink: 0;
  transition: transform 0.2s;
}

details[open] .faq-q::after {
  transform: rotate(45deg);
}

.faq-a {
  padding: 0 20px 18px;
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.7;
}

@media (max-width: 620px) {
  .plans-grid { grid-template-columns: 1fr; }
  .plan-badge { font-size: 10px; }
  #pricing-hero { padding: 64px 16px 32px; }
  #plans { padding: 32px 16px 56px; }
  .plan-card { padding: 24px; }
  .price-amount { font-size: 34px; }
  #faq { padding: 0 16px 72px; }
  .plans-footnote { flex-direction: column; align-items: center; gap: 12px; }
  .current-sub-banner { flex-wrap: wrap; }
}
</style>
