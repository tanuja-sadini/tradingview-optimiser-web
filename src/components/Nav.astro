---
import { interpretSubscription, planLabel, type Subscription } from '../lib/subscription';

interface Props {
  user?: { email: string | null } | null;
  subscription?: Subscription | null;
}
const { user, subscription = null } = Astro.props;

const sub = interpretSubscription(subscription);
---

<nav id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="TradingView Strategy Optimizer">
      <img src="/logo.png" alt="" aria-hidden="true" class="nav-logo-icon" />
      <span class="nav-logo-text">TVO</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="/#how-it-works">How It Works</a></li>
      <li><a href="/#features">Features</a></li>
      <li><a href="/#analytics">Analytics</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/download">Download</a></li>
    </ul>

    <div class="nav-actions">
      {user ? (
        <div class="nav-account" id="navAccount">
          <button class="nav-account-btn" id="navAccountBtn" aria-haspopup="true" aria-expanded="false">
            <span class="nav-account-email">{user.email ?? 'Account'}</span>
            <svg class="nav-account-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="nav-dropdown" id="navDropdown" role="menu">
            {sub.state === 'paid-active' && (
              <div class="nav-dropdown-plan">
                <span class="nav-plan-dot"></span>
                {planLabel(sub.plan_id)} plan
              </div>
            )}
            {sub.state === 'trial-active' && (
              <div class="nav-dropdown-plan nav-dropdown-plan--trial">
                <span class="nav-plan-dot"></span>
                Trial — {sub.daysRemaining} day{sub.daysRemaining === 1 ? '' : 's'} left
              </div>
            )}
            {sub.state === 'trial-expired' && (
              <div class="nav-dropdown-plan nav-dropdown-plan--expired">
                <span class="nav-plan-dot"></span>
                Trial expired
              </div>
            )}
            {sub.state === 'billing-issue' && (
              <div class="nav-dropdown-plan nav-dropdown-plan--issue">
                <span class="nav-plan-dot"></span>
                Billing issue
              </div>
            )}
            <a href="/dashboard" class="nav-dropdown-item" role="menuitem">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
                <rect x="9" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
                <rect x="2" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
                <rect x="9" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
              </svg>
              Dashboard
            </a>
            <div class="nav-dropdown-divider"></div>
            <a href="/auth/logout" class="nav-dropdown-item nav-dropdown-item--danger" role="menuitem">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M6 14H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h3M11 11l3-3-3-3M14 8H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Sign out
            </a>
          </div>
        </div>
      ) : (
        <>
          <a href="/auth/login" class="btn-ghost nav-cta">Log In</a>
          <a href="/pricing" class="btn-primary nav-cta">Get Started</a>
        </>
      )}
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 24px;
    border-bottom: 1px solid transparent;
    transition: background 0.2s, border-color 0.2s;
  }

  nav.scrolled {
    background: rgba(30,31,34,0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: var(--border);
  }

  .nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: contain;
  }

  .nav-logo-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    flex: 1;
    justify-content: center;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .nav-links a:hover {
    color: var(--text-primary);
    background: var(--bg-panels);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Account dropdown */
  .nav-account {
    position: relative;
  }

  .nav-account-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 6px 10px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }

  .nav-account-btn:hover,
  .nav-account-btn[aria-expanded="true"] {
    background: var(--bg-panels);
    border-color: rgba(255,255,255,0.12);
  }

  .nav-account-email {
    font-size: 12px;
    color: var(--text-muted);
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-account-btn:hover .nav-account-email,
  .nav-account-btn[aria-expanded="true"] .nav-account-email {
    color: var(--text-primary);
  }

  .nav-account-chevron {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .nav-account-btn[aria-expanded="true"] .nav-account-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: var(--bg-elevated);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    padding: 4px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    z-index: 200;
  }

  .nav-dropdown.open {
    display: block;
  }

  .nav-dropdown-plan {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 12px 6px;
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  .nav-plan-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  .nav-dropdown-plan--trial    { color: var(--yellow); }
  .nav-dropdown-plan--expired,
  .nav-dropdown-plan--issue    { color: var(--red); }

  .nav-dropdown-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 9px 12px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background 0.12s, color 0.12s;
  }

  .nav-dropdown-item:hover {
    background: var(--bg-panels);
    color: var(--text-primary);
  }

  .nav-dropdown-item--danger:hover {
    background: rgba(242,63,67,0.1);
    color: var(--red);
  }

  .nav-dropdown-divider {
    height: 1px;
    background: var(--border);
    margin: 4px 0;
  }

  @media (max-width: 700px) {
    .nav-links { display: none; }
  }
</style>

<script>
  const btn      = document.getElementById('navAccountBtn');
  const dropdown = document.getElementById('navDropdown');

  if (btn && dropdown) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });

    // Close on outside click
    document.addEventListener('click', () => {
      dropdown.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        btn.focus();
      }
    });
  }
</script>
