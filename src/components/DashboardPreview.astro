---
---

<div class="dashboard-preview reveal" style="transition-delay:0.15s" role="img" aria-label="Preview of the ranked results dashboard">

  <div class="window-chrome">
    <div class="window-dots" aria-hidden="true">
      <div class="window-dot red"></div>
      <div class="window-dot yellow"></div>
      <div class="window-dot green"></div>
    </div>
    <div class="window-title">TradingView Optimizer — ES_15s_2026</div>
  </div>

  <div class="window-body">
    <div class="window-sidebar" aria-hidden="true">
      <div class="sidebar-icon" title="Parameters">🎛️</div>
      <div class="sidebar-icon" title="Run">▶️</div>
      <div class="sidebar-icon active" title="Results">📊</div>
      <div class="sidebar-icon" title="Logs">📋</div>
    </div>

    <div class="window-content">
      <div class="results-tabs" role="tablist" aria-label="Results views">
        <div class="results-tab active" role="tab">Ranked Table</div>
        <div class="results-tab" role="tab">Impact Charts</div>
        <div class="results-tab" role="tab">Heatmap</div>
        <div class="results-tab" role="tab">Scatter</div>
        <div class="results-tab" role="tab">Compare</div>
      </div>

      <div class="run-info" aria-label="Run summary">
        <div class="run-info-item">
          <span class="run-badge green">✓ Complete</span>
        </div>
        <div class="run-info-item">
          <span class="mono" style="color:var(--text-primary)">1,848</span>
          <span>combinations</span>
        </div>
        <div class="run-info-item">
          <span>ES · 15s · 90-day backtest</span>
        </div>
        <div class="run-info-item" style="margin-left:auto">
          <span class="run-badge blue">Sweep A — Conservative</span>
        </div>
      </div>

      <div class="results-table-wrap" role="region" aria-label="Results table">
        <table class="results-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Score</th>
              <th>TP Dist</th>
              <th>SL Dist</th>
              <th>HTF TF</th>
              <th>Filter</th>
              <th class="right">Net P&amp;L</th>
              <th class="right">Win Rate</th>
              <th class="right">Prof. Factor</th>
              <th class="right">Max DD</th>
              <th class="right">Trades</th>
            </tr>
          </thead>
          <tbody>
            <tr class="gold">
              <td><span class="rank-medal" aria-label="Gold">🥇</span></td>
              <td><div class="score-bar-wrap"><span class="mono">87.3</span><div class="score-bar-bg"><div class="score-bar-fill" style="width:87.3%"></div></div></div></td>
              <td class="mono">25</td><td class="mono">15</td><td class="mono">15m</td>
              <td><span class="val-green mono">true</span></td>
              <td class="right val-green mono">+$12,450</td>
              <td class="right mono">68.4%</td>
              <td class="right mono">2.31</td>
              <td class="right val-red mono">−8.2%</td>
              <td class="right val-dim mono">312</td>
            </tr>
            <tr class="silver">
              <td><span class="rank-medal" aria-label="Silver">🥈</span></td>
              <td><div class="score-bar-wrap"><span class="mono">84.1</span><div class="score-bar-bg"><div class="score-bar-fill" style="width:84.1%"></div></div></div></td>
              <td class="mono">20</td><td class="mono">10</td><td class="mono">5m</td>
              <td><span class="val-green mono">true</span></td>
              <td class="right val-green mono">+$10,820</td>
              <td class="right mono">71.2%</td>
              <td class="right mono">2.08</td>
              <td class="right val-red mono">−9.5%</td>
              <td class="right val-dim mono">489</td>
            </tr>
            <tr class="bronze">
              <td><span class="rank-medal" aria-label="Bronze">🥉</span></td>
              <td><div class="score-bar-wrap"><span class="mono">79.6</span><div class="score-bar-bg"><div class="score-bar-fill" style="width:79.6%"></div></div></div></td>
              <td class="mono">30</td><td class="mono">15</td><td class="mono">15m</td>
              <td><span class="val-dim mono">false</span></td>
              <td class="right val-green mono">+$9,340</td>
              <td class="right mono">62.1%</td>
              <td class="right mono">1.94</td>
              <td class="right val-red mono">−7.8%</td>
              <td class="right val-dim mono">274</td>
            </tr>
            <tr>
              <td><span class="mono val-dim">4</span></td>
              <td><div class="score-bar-wrap"><span class="mono">74.2</span><div class="score-bar-bg"><div class="score-bar-fill" style="width:74.2%;opacity:0.6"></div></div></div></td>
              <td class="mono">15</td><td class="mono">10</td><td class="mono">1h</td>
              <td><span class="val-green mono">true</span></td>
              <td class="right val-green mono">+$8,210</td>
              <td class="right mono">74.8%</td>
              <td class="right mono">1.77</td>
              <td class="right val-red mono">−11.3%</td>
              <td class="right val-dim mono">198</td>
            </tr>
            <tr>
              <td><span class="mono val-dim">5</span></td>
              <td><div class="score-bar-wrap"><span class="mono">71.8</span><div class="score-bar-bg"><div class="score-bar-fill" style="width:71.8%;opacity:0.5"></div></div></div></td>
              <td class="mono">35</td><td class="mono">20</td><td class="mono">5m</td>
              <td><span class="val-dim mono">false</span></td>
              <td class="right val-green mono">+$7,890</td>
              <td class="right mono">58.3%</td>
              <td class="right mono">1.89</td>
              <td class="right val-red mono">−13.1%</td>
              <td class="right val-dim mono">521</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<style>
  .dashboard-preview {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    overflow: hidden;
    border: 1px solid var(--border);
    border-bottom: none;
    box-shadow: 0 -8px 64px rgba(88,101,242,0.12), 0 0 0 1px rgba(255,255,255,0.04);
  }

  .dashboard-preview::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent, var(--bg-darkest));
    pointer-events: none;
  }

  .window-chrome {
    background: var(--bg-elevated);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border);
  }

  .window-dots { display: flex; gap: 6px; }
  .window-dot { width: 12px; height: 12px; border-radius: 50%; }
  .window-dot.red    { background: #FF5F57; }
  .window-dot.yellow { background: #FFBD2E; }
  .window-dot.green  { background: #28C840; }

  .window-title {
    font-size: 12px;
    color: var(--text-muted);
    font-family: 'Noto Sans Mono', monospace;
    flex: 1;
    text-align: center;
  }

  .window-body { display: flex; background: var(--bg-darkest); height: 420px; }

  .window-sidebar {
    width: 52px;
    background: var(--bg-panels);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 0;
    gap: 8px;
    flex-shrink: 0;
  }

  .sidebar-icon {
    width: 36px; height: 36px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    color: var(--text-muted);
  }
  .sidebar-icon.active {
    background: rgba(88,101,242,0.2);
    color: var(--accent);
  }

  .window-content { flex: 1; overflow: hidden; display: flex; flex-direction: column; }

  .results-tabs {
    display: flex;
    gap: 2px;
    padding: 8px 12px 0;
    border-bottom: 1px solid var(--border);
    background: var(--bg-panels);
  }

  .results-tab {
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    color: var(--text-muted);
  }
  .results-tab.active {
    background: var(--bg-darkest);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-bottom: 1px solid var(--bg-darkest);
    margin-bottom: -1px;
  }

  .run-info {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 8px 16px;
    font-size: 12px;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    background: var(--bg-panels);
  }

  .run-info-item { display: flex; align-items: center; gap: 5px; }

  .run-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    font-family: 'Noto Sans Mono', monospace;
  }
  .run-badge.green { background: rgba(35,165,90,0.15); color: var(--green); }
  .run-badge.blue  { background: rgba(88,101,242,0.15); color: var(--accent); }

  .results-table-wrap { overflow: auto; flex: 1; }

  .results-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    font-family: 'Noto Sans Mono', monospace;
  }

  .results-table th {
    padding: 8px 14px;
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg-panels);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    position: sticky; top: 0;
  }

  .results-table th.right,
  .results-table td.right { text-align: right; }

  .results-table td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    color: var(--text-primary);
  }

  .results-table tr.gold   td { background: var(--gold-bg); }
  .results-table tr.silver td { background: var(--silver-bg); }
  .results-table tr.bronze td { background: var(--bronze-bg); }

  .score-bar-wrap { display: flex; align-items: center; gap: 8px; }
  .score-bar-bg { width: 60px; height: 4px; background: var(--bg-elevated); border-radius: 2px; overflow: hidden; }
  .score-bar-fill { height: 100%; border-radius: 2px; background: var(--accent); }

  .val-green { color: var(--green); }
  .val-red   { color: var(--red); }
  .val-dim   { color: var(--text-muted); }

  @media (max-width: 720px) {
    .window-body { height: 280px; }
    .window-sidebar { display: none; }
    .results-table th:nth-child(n+7),
    .results-table td:nth-child(n+7) { display: none; }
  }
</style>
